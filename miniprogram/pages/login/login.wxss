.container {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-box {
  width: 80%;
  padding: 40rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.logo {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #1976d2;
}

.form-item {
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.input:focus {
  border-color: #1976d2;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 20rpx;
  font-size: 32rpx;
}

.tips {
  text-align: center;
  margin-top: 30rpx;
}

.link {
  color: #1976d2;
  font-size: 28rpx;
}

.admin-tip {
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
}
