<view class="container">
  <view class="login-box">
    <view class="logo">
      <text class="logo-text">🔒 LOTO QR</text>
    </view>
    
    <view class="form-item">
      <input class="input" placeholder="请输入用户名" bindinput="onUsernameInput" value="{{username}}" />
    </view>
    
    <view class="form-item">
      <input class="input" placeholder="请输入密码" password="{{true}}" bindinput="onPasswordInput" value="{{password}}" />
    </view>
    
    <button class="login-btn btn-primary" bindtap="onLogin" loading="{{loading}}">登录</button>
    
    <view class="tips" wx:if="{{userInfo && userInfo.role === 'admin'}}">
      <text class="link" bindtap="goToRegister">注册新用户</text>
    </view>
    
    <view class="admin-tip">
      <text class="text-muted">管理员账号: SARL2LOTO / EHS123456</text>
    </view>
  </view>
</view>
