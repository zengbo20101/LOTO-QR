.container {
  padding: 20rpx;
}

.header {
  background: white;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.welcome {
  font-size: 32rpx;
  font-weight: bold;
}

.logout {
  font-size: 26rpx;
  color: #1976d2;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 15rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  background: white;
  border-radius: 12rpx;
  padding: 25rpx 15rpx;
  text-align: center;
}

.stat-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #1976d2;
}

.quick-actions {
  display: flex;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.action-item {
  flex: 1;
  background: white;
  border-radius: 12rpx;
  padding: 30rpx 15rpx;
  text-align: center;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-text {
  font-size: 24rpx;
  color: #333;
}

.latest-section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-title {
  font-size: 28rpx;
  font-weight: bold;
}

.record-status {
  font-size: 22rpx;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
}

.status-locked {
  color: #e74c3c;
  background: rgba(231, 76, 60, 0.1);
}

.status-unlocked {
  color: #2ecc71;
  background: rgba(46, 204, 113, 0.1);
}

.record-info {
  display: flex;
  gap: 15rpx;
}

.info-item {
  font-size: 22rpx;
  color: #999;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
}
