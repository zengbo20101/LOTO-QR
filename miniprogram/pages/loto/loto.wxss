.container {
  padding: 20rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 30rpx;
}

.add-btn .icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.filter-section {
  background: white;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.filter-picker {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
}

.loto-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.loto-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.loto-title {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.device-name {
  font-size: 32rpx;
  font-weight: bold;
}

.loto-status {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-locked {
  background: rgba(231, 76, 60, 0.1);
  color: #e74c3c;
}

.status-unlocked {
  background: rgba(46, 204, 113, 0.1);
  color: #2ecc71;
}

.loto-time {
  font-size: 24rpx;
  color: #999;
}

.loto-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.info-row .label {
  color: #666;
  width: 120rpx;
}

.info-row .value {
  flex: 1;
  color: #333;
}

.loto-actions {
  display: flex;
  gap: 15rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.loto-actions .btn-sm {
  flex: 1;
  font-size: 24rpx;
}

.btn-warning {
  background: #f39c12;
  color: white;
}

.btn-danger {
  background: #e74c3c;
  color: white;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
}
