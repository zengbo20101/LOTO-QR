.container {
  padding: 20rpx;
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 30rpx;
}

.add-btn .icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.device-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.device-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.device-no {
  background: #1976d2;
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.device-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
}

.qr-container {
  display: flex;
  justify-content: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.qr-image {
  width: 300rpx;
  height: 300rpx;
}

.device-info {
  margin-bottom: 20rpx;
}

.info-text {
  font-size: 26rpx;
  color: #666;
}

.device-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
}

.btn-sm {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  padding: 40rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-body {
  padding: 40rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.modal-footer .btn {
  flex: 1;
  border: none;
  background: none;
  padding: 30rpx;
  font-size: 30rpx;
}

.btn-default {
  border-right: 1rpx solid #eee;
}

.btn-primary {
  color: #1976d2;
}
